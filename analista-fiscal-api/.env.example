# =====================================================================
# Analista Fiscal API — .env.example
# ---------------------------------------------------------------------
# Copie pra .env e preencha. Cada bloco tem uma linha "DECISÃO:"
# explicando por que esse default existe. Fonte de verdade:
# ./DEPLOY.md (raiz do sub-projeto backend).
#
# Geração de segredos:
#   JWT_SECRET             → openssl rand -hex 32
#   PLUGGY_WEBHOOK_SECRET  → openssl rand -hex 32
#   SERPRO_CERT_ENC_KEY    → openssl rand -base64 32
#   MARKETPLACE_ADMIN_TOK  → openssl rand -hex 32
# =====================================================================


# ─── 1. Ambiente ──────────────────────────────────────────────────────
# DECISÃO: ENVIRONMENT=prod ativa _fail_fast_em_prod() que bloqueia
# localhost em DATABASE_URL/REDIS_URL. Use 'local' em dev (defaults
# servem direto), 'staging' em QA, 'prod' só com infra real.
ENVIRONMENT=local
LOG_LEVEL=INFO


# ─── 2. Banco + Cache ─────────────────────────────────────────────────
# Postgres expõe porta 5434 no docker-compose (mapeada de 5432) pra não
# colidir com Postgres do host. Em prod use porta padrão 5432.
DATABASE_URL=postgresql+asyncpg://fiscal:fiscal@localhost:5434/fiscal
REDIS_URL=redis://localhost:6379/0

# Pool config (Sprint 19 PR1 — calibrado pra 1k empresas concorrentes).
# Default SQLAlchemy (5+10) estoura. Mexer só com profiling antes/depois.
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# DECISÃO: slow query log ativo por default (>=500ms vira log estruturado
# 'db.slow_query'). Setar 0 ou negativo desliga o listener.
SLOW_QUERY_THRESHOLD_MS=500


# ─── 3. LLM (Ollama dev / Gemini prod) ────────────────────────────────
# DECISÃO ARQUITETURAL — rota dual:
#   • Dev local: Ollama + Gemma 3 4B Q4_K_M (zero custo, privacy total).
#     Modelo precisa ser pulled: `ollama pull gemma3:4b`.
#   • Prod: Gemini 2.5 Flash (Lite por default, Flash quando precisa,
#     Pro só pra contábil avançado). Custo ~R$0,30/M tokens input.
#   • Dados sensíveis (CPF, valores fiscais — flag contem_pii=True)
#     CONTINUAM roteados pra Ollama mesmo em prod (§7 LGPD).
#   • Sem GEMINI_API_KEY em prod → fallback automático pra Ollama
#     (degradação graceful, latência sobe mas sistema funciona).
OLLAMA_URL=http://localhost:11434
GEMINI_API_KEY=

# Langfuse (tracing LLM self-hosted BR — opcional).
# DECISÃO: desligado por default. Ativa quando o stack Langfuse self-hosted
# (Sprint 21 hardening) estiver no ar — antes disso só polui o destino.
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=


# ─── 4. JWT ───────────────────────────────────────────────────────────
# DECISÃO: placeholder força override consciente. Gerar com:
#   openssl rand -hex 32     (32 bytes = 64 hex chars)
# HS256 hoje. RS256 reservado pra Sprint 13+ quando marketplace exigir
# rotação de chaves sem reencrypt de tokens emitidos.
JWT_SECRET=TROCAR_EM_PRODUCAO_gere_com_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60


# ─── 5. Focus NFe (emissão NFS-e) ─────────────────────────────────────
# DECISÃO: SANDBOX=true em dev pra nunca emitir NFS-e real por engano.
# Em prod precisa flip explícito + token de produção da Focus.
# FOCUS_NFSE_ENVIA_CBS_IBS desligado até Focus documentar API completa
# (hoje só 7 prefeituras-piloto ADN; pendência #19).
FOCUS_NFE_TOKEN=
FOCUS_NFE_SANDBOX=true
FOCUS_NFSE_ENVIA_CBS_IBS=false


# ─── 6. Meta WhatsApp Cloud API ───────────────────────────────────────
# DECISÃO: template "weekly_digest_pt_br" precisa estar aprovado no
# painel Meta antes de ATIVO=true. Antes disso, digest gera snapshot
# com status='preparado' mas não envia (fail-closed por construção).
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=
META_WHATSAPP_APP_SECRET=
META_WHATSAPP_VERIFY_TOKEN=fiscalai-webhook-verify
WHATSAPP_DIGEST_TEMPLATE_NAME=weekly_digest_pt_br
WHATSAPP_DIGEST_LANG_CODE=pt_BR
WHATSAPP_DIGEST_TEMPLATE_ATIVO=false


# ─── 7. BrasilAPI (CNPJ lookup público) ───────────────────────────────
# DECISÃO: API pública sem auth. Cache Redis 30d evita rate limit.
BRASIL_API_URL=https://brasilapi.com.br


# ─── 8. SERPRO Integra Contador ───────────────────────────────────────
# DECISÃO: SANDBOX=true em dev pra não consumir cota real do SERPRO
# (PGDAS-D, certidões CND/CRF têm cota mensal contratada).
# SERPRO_CERT_ENCRYPTION_KEY: chave simétrica que envelopa o e-CNPJ (.p12)
# do cliente em pgcrypto. Em prod vem de KMS, não de envvar direto. Gerar:
#   openssl rand -base64 32
SERPRO_BASE_URL=https://apigateway.serpro.gov.br
SERPRO_CONSUMER_KEY=
SERPRO_CONSUMER_SECRET=
SERPRO_SANDBOX=true
SERPRO_OAUTH_TTL_MARGIN_SEC=60
SERPRO_CERT_ENCRYPTION_KEY=


# ─── 9. Pluggy Open Finance ───────────────────────────────────────────
# DECISÃO: PLUGGY_WEBHOOK_SECRET vazio = HMAC valida com string vazia,
# o que rejeita tudo (fail-closed por construção). Em prod precisa
# combinar com o webhook secret cadastrado no painel pluggy.ai.
PLUGGY_BASE_URL=https://api.pluggy.ai
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_WEBHOOK_SECRET=
PLUGGY_CONNECT_TOKEN_TTL_MIN=30
PLUGGY_API_KEY_TTL_MARGIN_SEC=120


# ─── 10. Admin tokens ─────────────────────────────────────────────────
# DECISÃO: ambos vazios por default. MARKETPLACE_ADMIN_TOKEN="" faz
# endpoints /v1/admin/* retornarem 503 (fail-closed). Idem
# /v1/admin/tabelas/* da Sprint 19.5 que reusa esse mesmo token.
MARKETPLACE_ADMIN_TOKEN=

# DECISÃO: opcional. Quando configurado, o digest semanal (Sprint 15.5)
# inclui bullets com os alertas críticos do painel admin (Sprint 19.5
# PR2) endereçados pra esse número. Vazio = noop, alertas só na API.
ADMIN_WHATSAPP_PHONE=
