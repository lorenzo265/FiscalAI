# Environment: local | dev | staging | prod
ENVIRONMENT=local
LOG_LEVEL=INFO

# Database — Postgres 16
# Porta 5433 no host para não conflitar com Postgres local instalado na máquina
DATABASE_URL=postgresql+asyncpg://fiscal:fiscal@localhost:5434/fiscal

# Redis — cache + Celery broker (Sprint 2+)
REDIS_URL=redis://localhost:6379/0

# Ollama — LLM local (Sprint 3+)
OLLAMA_URL=http://localhost:11434

# JWT — Sprint 1
# Gerar com: openssl rand -hex 32
JWT_SECRET=TROCAR_EM_PRODUCAO_gere_com_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
